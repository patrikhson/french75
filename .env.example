# Copy this to .env and fill in values. Never commit .env.

APP_ENV=development
PORT=8080

# PostgreSQL — use a local DB for development
# Production: postgres://french75:PASSWORD@vm04.paftech.se:5432/french75?sslmode=require
DATABASE_URL=postgres://french75:password@localhost:5432/french75?sslmode=disable

# Security — generate with: openssl rand -hex 32
SESSION_SECRET=changeme
CSRF_KEY=changeme

# Invite-only mode (true = only invited users can register)
INVITE_ONLY=true

# Google OAuth
# Get from: console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Authorized redirect URIs: http://localhost:8080/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# WebAuthn (Yubikey)
# RPID must match the domain users visit (no port, no scheme)
WEBAUTHN_RPID=localhost
WEBAUTHN_RPORIGIN=http://localhost:8080
WEBAUTHN_RPDISPLAYNAME=French 75 Tracker

# Photo storage
STORAGE_PATH=./photos
STORAGE_URL_PREFIX=http://localhost:8080/photos

# App base URL (used for OAuth redirect URIs, invite links)
APP_BASE_URL=http://localhost:8080

# SMTP — use the MX host for the sender domain, not localhost
# (the app may run on a different host than the mail server)
SMTP_HOST=mail.paftech.se
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
